{
  "name": "promonight-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "tsx scripts/generate-indexnow-key-file.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit:ticketmaster": "tsx --env-file=.env.local --require ./scripts/stub-server-only.cjs scripts/audit-ticketmaster-urls.ts",
    "map:ticketmaster": "tsx --env-file=.env.local --require ./scripts/stub-server-only.cjs scripts/ticketmaster-team-mapping.ts",
    "map:ticketmaster:rerun": "tsx --env-file=.env.local --require ./scripts/stub-server-only.cjs scripts/ticketmaster-team-mapping.ts --rerun",
    "populate:ticketmaster": "tsx --env-file=.env.local --require ./scripts/stub-server-only.cjs scripts/populate-ticketmaster-fields.ts",
    "populate:fanatics": "tsx --env-file=.env.local --require ./scripts/stub-server-only.cjs scripts/populate-fanatics-paths.ts",
    "migrate:fanatics-url": "tsx --env-file=.env.local --require ./scripts/stub-server-only.cjs scripts/migrate-fanatics-path-to-url.ts"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "next": "^15.3.1",
    "posthog-js": "^1.370.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@google-analytics/data": "^5.2.2",
    "@napi-rs/canvas": "^0.1.99",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "dotenv": "^17.4.2",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  }
}
