{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/mlb-schedule",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/weekly-digest?execute=true",
      "schedule": "0 17 * * 2"
    },
    {
      "path": "/api/cron/indexnow-daily",
      "schedule": "10 6 * * *"
    }
  ]
}
