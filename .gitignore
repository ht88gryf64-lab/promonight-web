# dependencies
node_modules/

# next.js
.next/
out/

# production
build/

# env files
.env*.local

# misc
.DS_Store
*.tsbuildinfo
next-env.d.ts
.vercel

# cached fonts for OG image generator (scripts/generate-og.ts)
scripts/.fonts/

# generated audit output — regenerated via `npm run audit:ticketmaster`
scripts/ticketmaster-url-audit.csv

# generated Discovery API mapping — regenerated via `npm run map:ticketmaster`
# CSV is reviewer-facing, JSON is consumed by follow-up code edits; neither
# is canonical (Firestore is) so both stay out of git
scripts/ticketmaster-team-mapping.csv
scripts/ticketmaster-team-mapping.json
scripts/ticketmaster-team-mapping-rerun.csv
scripts/ticketmaster-team-mapping-rerun.json

# error log written by the mapping script when the Discovery API returns
# non-2xx or fetch throws — apikey is redacted before write, but keep it
# out of git as a hygiene measure
scripts/ticketmaster-mapping-errors.log

# IndexNow key verification file — generated at prebuild from INDEXNOW_KEY env var
public/*.txt
# but DO commit ads.txt — required for AdSense verification, served at /ads.txt
!public/ads.txt

# throwaway promo-pipeline prototypes
promo-pipeline/prototypes/
